# ============================================================
# HAVK Dashboard — environment configuration
# Copy this file to .env.local for local development
# (.env.local is gitignored — never commit real values)
# ============================================================

# --- Supabase Postgres connection strings ---------------------------------
# In Supabase: Project Settings -> Database -> Connection string
# DATABASE_URL: use the "Transaction" pooler (port 6543) — used at runtime
# by the Next.js app (serverless-friendly connection pooling).
DATABASE_URL="postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require"

# DIRECT_URL: use the "Session" / direct connection (port 5432) — used only
# for running migrations and the seed script, which need a non-pooled
# connection.
DIRECT_URL="postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require"

# --- App / session config ---------------------------------------------------
# Base URL the app is served from (used for links in notifications, etc.)
APP_URL="http://localhost:3000"

# Display name for the organization, shown in the header/branding.
NEXT_PUBLIC_ORG_NAME="HAVK"

# Session cookie name (rarely needs to change).
SESSION_COOKIE_NAME="havk_session"

# --- Login security ----------------------------------------------------------
# Max failed login attempts (per name+IP) before a temporary lockout.
LOGIN_MAX_ATTEMPTS=5
# Max failed login attempts against one member name across ALL IPs before a
# temporary lockout — stops an attacker who rotates IPs to dodge the per-IP
# limit above. Deliberately higher than LOGIN_MAX_ATTEMPTS.
LOGIN_GLOBAL_MAX_ATTEMPTS=20
# Lockout duration in minutes after exceeding either limit above.
LOGIN_LOCKOUT_MINUTES=15
# Session lifetime in hours before a member must log in again.
SESSION_LIFETIME_HOURS=12

# --- Seeding ------------------------------------------------------------------
# Path (relative to repo root) to the private, gitignored member roster used
# by `npm run db:seed`. See README.md "Adding Members" for the file format.
MEMBERS_SEED_FILE="members.private.json"

# Set to "true" to additionally load non-sensitive demo data (sample tasks,
# ideas, meetings, grants, expenses) after seeding members. Demo credentials
# are separate from real member codes — see members.demo.json.
LOAD_DEMO_DATA="false"

# --- Email notifications (optional) ------------------------------------------
# Both unset by default — email notifications are silently skipped and the
# app works fully on in-app notifications alone. To enable: create a free
# account at resend.com, copy your API key, and set a "from" address. See
# README.md "Email notifications" for the free-tier sandbox limitation.
RESEND_API_KEY=""
EMAIL_FROM="HAVK Dashboard <onboarding@resend.dev>"
